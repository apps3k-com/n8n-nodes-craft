{
  "_comment": "Codex hooks — reuse the SAME provider-neutral scripts as Claude Code (../.claude/hooks/*.sh), which block via exit code 2 + stderr. Codex has no per-hook 'if' matcher or env field, so every PreToolUse(Bash) script self-guards (greps the command and exits 0 when it does not apply) and config is exported inline (PROTECTED_BRANCH=main; WORKFLOW_REQUIRE_ISSUE_REF=true makes pr-validate require a 'Closes #N' issue link in the PR body, set to false to relax). Explicit timeouts mirror .claude/settings.json (Codex default is 600s). Format per https://developers.openai.com/codex/hooks.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "PROTECTED_BRANCH=main bash \"$(git rev-parse --show-toplevel)/.claude/hooks/commit-guard.sh\"", "timeout": 10 },
          { "type": "command", "command": "PROTECTED_BRANCH=main bash \"$(git rev-parse --show-toplevel)/.claude/hooks/branch-name-guard.sh\"", "timeout": 10 },
          { "type": "command", "command": "PROTECTED_BRANCH=main bash \"$(git rev-parse --show-toplevel)/.claude/hooks/push-guard.sh\"", "timeout": 10 },
          { "type": "command", "command": "PROTECTED_BRANCH=main bash \"$(git rev-parse --show-toplevel)/.claude/hooks/merge-guard.sh\"", "timeout": 10 },
          { "type": "command", "command": "PROTECTED_BRANCH=main bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pr-merge-guard.sh\"", "timeout": 10 },
          { "type": "command", "command": "PROTECTED_BRANCH=main WORKFLOW_REQUIRE_ISSUE_REF=true bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pr-validate.sh\"", "timeout": 10 }
        ]
      }
    ],
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "PROTECTED_BRANCH=main bash \"$(git rev-parse --show-toplevel)/.claude/hooks/session-init.sh\"", "timeout": 5 } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/self-review.sh\"", "timeout": 5 } ] }
    ]
  }
}
